<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="font-heading text-2xl font-bold text-mc-light">Panel administracyjny</h1>
      <p class="text-mc-muted text-sm mt-2">Magnolia Club</p>
    </div>

    <% if (error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
        <%= error %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST" class="bg-white rounded-xl border border-gray-200 p-8 space-y-6 shadow-sm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div>
        <label for="username" class="block text-sm font-medium text-mc-light mb-2">Nazwa użytkownika</label>
        <input type="text" id="username" name="username" required autofocus
               class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors">
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-mc-light mb-2">Hasło</label>
        <input type="password" id="password" name="password" required
               class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors">
      </div>

      <button type="submit" class="w-full bg-mc-accent hover:bg-mc-highlight text-white font-semibold py-3 rounded-lg transition-all">
        Zaloguj się
      </button>
    </form>

    <p class="text-center text-mc-muted text-xs mt-6">
      <a href="/" class="hover:text-mc-accent transition-colors">&larr; Wróć do strony</a>
    </p>
  </div>
</div>
