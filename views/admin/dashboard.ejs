<h1 class="font-heading text-2xl font-bold text-mc-light mb-8">Panel administracyjny</h1>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <p class="text-mc-muted text-xs uppercase tracking-wider mb-1">Wszystkie wycieczki</p>
    <p class="text-3xl font-bold text-mc-light"><%= stats.totalTours %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <p class="text-mc-muted text-xs uppercase tracking-wider mb-1">Aktywne wycieczki</p>
    <p class="text-3xl font-bold text-green-600"><%= stats.activeTours %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <p class="text-mc-muted text-xs uppercase tracking-wider mb-1">Wszystkie zapytania</p>
    <p class="text-3xl font-bold text-mc-light"><%= stats.totalContacts %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <p class="text-mc-muted text-xs uppercase tracking-wider mb-1">Nieprzeczytane</p>
    <p class="text-3xl font-bold text-mc-accent"><%= stats.unreadContacts %></p>
  </div>
</div>

<!-- Quick Actions -->
<div class="flex flex-wrap gap-3 mb-10">
  <a href="/admin/tours/add" class="bg-mc-accent hover:bg-mc-highlight text-white font-semibold px-5 py-2.5 rounded-lg transition-all text-sm">+ Dodaj wycieczkę</a>
  <a href="/admin/blog/add" class="bg-white hover:bg-gray-50 text-mc-light font-medium px-5 py-2.5 rounded-lg transition-all text-sm border border-gray-200">+ Dodaj wpis na blog</a>
  <a href="/admin/contacts" class="bg-white hover:bg-gray-50 text-mc-light font-medium px-5 py-2.5 rounded-lg transition-all text-sm border border-gray-200">Zapytania<% if (stats.unreadContacts > 0) { %> <span class="bg-mc-accent text-white text-xs px-2 py-0.5 rounded-full ml-1"><%= stats.unreadContacts %></span><% } %></a>
</div>

<!-- Recent Contacts -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="font-heading font-semibold text-mc-light">Ostatnie zapytania</h2>
  </div>

  <% if (recentContacts.length === 0) { %>
    <div class="px-6 py-8 text-center text-mc-muted text-sm">Brak zapytań.</div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-mc-muted text-xs uppercase tracking-wider border-b border-gray-200">
            <th class="text-left px-6 py-3">Imię</th>
            <th class="text-left px-6 py-3">Email</th>
            <th class="text-left px-6 py-3 hidden md:table-cell">Wycieczka</th>
            <th class="text-left px-6 py-3 hidden lg:table-cell">Data</th>
            <th class="text-left px-6 py-3">Status</th>
          </tr>
        </thead>
        <tbody>
          <% recentContacts.forEach(c => { %>
            <tr class="border-b border-gray-200 hover:bg-gray-50">
              <td class="px-6 py-3 text-mc-light font-medium"><%= c.name %></td>
              <td class="px-6 py-3 text-mc-muted"><%= c.email %></td>
              <td class="px-6 py-3 text-mc-muted hidden md:table-cell"><%= c.tour_title || '—' %></td>
              <td class="px-6 py-3 text-mc-muted hidden lg:table-cell"><%= new Date(c.created_at).toLocaleDateString('pl-PL') %></td>
              <td class="px-6 py-3">
                <% if (c.read) { %>
                  <span class="text-xs text-mc-muted">Przeczytane</span>
                <% } else { %>
                  <span class="text-xs bg-mc-accent/10 text-mc-accent px-2 py-1 rounded-full">Nowe</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
