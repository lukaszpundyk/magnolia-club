<div class="flex items-center justify-between mb-8">
  <h1 class="font-heading text-2xl font-bold text-mc-light">Wycieczki</h1>
  <a href="/admin/tours/add" class="bg-mc-accent hover:bg-mc-highlight text-white font-semibold px-5 py-2.5 rounded-lg transition-all text-sm">+ Dodaj wycieczkę</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
  <% if (tours.length === 0) { %>
    <div class="px-6 py-12 text-center text-mc-muted">
      <p>Brak wycieczek. Dodaj pierwszą wycieczkę.</p>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-mc-muted text-xs uppercase tracking-wider border-b border-gray-200">
            <th class="text-left px-6 py-3">Nazwa</th>
            <th class="text-left px-6 py-3 hidden md:table-cell">Cel</th>
            <th class="text-left px-6 py-3 hidden lg:table-cell">Data</th>
            <th class="text-left px-6 py-3">Cena</th>
            <th class="text-left px-6 py-3 hidden sm:table-cell">Miejsca</th>
            <th class="text-left px-6 py-3">Status</th>
            <th class="text-right px-6 py-3">Akcje</th>
          </tr>
        </thead>
        <tbody>
          <% tours.forEach(tour => { %>
            <tr class="border-b border-gray-200 hover:bg-gray-50">
              <td class="px-6 py-3">
                <div class="flex items-center space-x-3">
                  <% if (tour.cover_image) { %>
                    <img src="/uploads/tours/<%= tour.cover_image %>" alt="" class="w-10 h-10 rounded object-cover flex-shrink-0">
                  <% } else { %>
                    <div class="w-10 h-10 rounded bg-mc-accent/10 flex-shrink-0"></div>
                  <% } %>
                  <div>
                    <p class="text-mc-light font-medium"><%= tour.title %></p>
                    <p class="text-mc-muted text-xs"><%= tour.days %> dni &bull; <%= tour.transport %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-3 text-mc-muted hidden md:table-cell"><%= tour.destination %></td>
              <td class="px-6 py-3 text-mc-muted hidden lg:table-cell">
                <%= tour.departure_date ? new Date(tour.departure_date).toLocaleDateString('pl-PL') : '—' %>
              </td>
              <td class="px-6 py-3 text-mc-light"><%= tour.price %> PLN</td>
              <td class="px-6 py-3 hidden sm:table-cell">
                <span class="<%= tour.available_spots < 5 ? 'text-red-500' : 'text-mc-muted' %>">
                  <%= tour.available_spots %>/<%= tour.max_participants %>
                </span>
              </td>
              <td class="px-6 py-3">
                <% if (tour.active) { %>
                  <span class="text-xs bg-green-50 text-green-600 px-2 py-1 rounded-full border border-green-200">Aktywna</span>
                <% } else { %>
                  <span class="text-xs bg-yellow-50 text-yellow-600 px-2 py-1 rounded-full border border-yellow-200">Szkic</span>
                <% } %>
                <% if (tour.featured) { %>
                  <span class="text-xs bg-mc-accent/10 text-mc-accent px-2 py-1 rounded-full ml-1">Wyróżniona</span>
                <% } %>
              </td>
              <td class="px-6 py-3">
                <div class="flex items-center justify-end space-x-2">
                  <a href="/admin/tours/edit/<%= tour.id %>" class="text-mc-accent hover:text-mc-highlight text-xs transition-colors">Edytuj</a>
                  <form action="/admin/tours/toggle/<%= tour.id %>" method="POST" class="inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="text-yellow-600 hover:text-yellow-700 text-xs transition-colors">
                      <%= tour.active ? 'Dezaktywuj' : 'Aktywuj' %>
                    </button>
                  </form>
                  <form action="/admin/tours/delete/<%= tour.id %>" method="POST" class="inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę wycieczkę?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="text-red-500 hover:text-red-600 text-xs transition-colors">Usuń</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
