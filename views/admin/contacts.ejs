<div class="flex items-center justify-between mb-8">
  <h1 class="font-heading text-2xl font-bold text-mc-light">Zapytania kontaktowe</h1>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
  <% if (contacts.length === 0) { %>
    <div class="px-6 py-12 text-center text-mc-muted text-sm">Brak zapytań.</div>
  <% } else { %>
    <div class="divide-y divide-gray-200">
      <% contacts.forEach(c => { %>
        <div class="p-6 hover:bg-gray-50 <%= !c.read ? 'border-l-2 border-l-mc-accent' : '' %>">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-grow min-w-0">
              <div class="flex items-center gap-3 mb-2">
                <h3 class="font-medium text-mc-light"><%= c.name %></h3>
                <% if (!c.read) { %>
                  <span class="text-xs bg-mc-accent/10 text-mc-accent px-2 py-0.5 rounded-full">Nowe</span>
                <% } %>
              </div>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-mc-muted mb-3">
                <span>
                  <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  <%= c.email %>
                </span>
                <% if (c.phone) { %>
                  <span>
                    <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    <%= c.phone %>
                  </span>
                <% } %>
                <% if (c.tour_title) { %>
                  <span>
                    <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    <%= c.tour_title %>
                  </span>
                <% } %>
                <span><%= new Date(c.created_at).toLocaleString('pl-PL') %></span>
              </div>
              <p class="text-sm text-mc-muted leading-relaxed whitespace-pre-line"><%= c.message %></p>
            </div>
            <div class="flex items-center space-x-2 flex-shrink-0">
              <% if (!c.read) { %>
                <form action="/admin/contacts/read/<%= c.id %>" method="POST">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="text-mc-accent hover:text-mc-highlight text-xs transition-colors whitespace-nowrap">Oznacz jako przeczytane</button>
                </form>
              <% } %>
              <form action="/admin/contacts/delete/<%= c.id %>" method="POST" onsubmit="return confirm('Usunąć to zapytanie?')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="text-red-500 hover:text-red-600 text-xs transition-colors">Usuń</button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
