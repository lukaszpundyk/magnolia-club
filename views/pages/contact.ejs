<!-- Hero -->
<section class="bg-gradient-to-b from-mc-dark to-mc-bg py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-mc-muted mb-4">
      <a href="/" class="hover:text-mc-accent transition-colors">Strona główna</a>
      <span class="mx-2">/</span>
      <span class="text-mc-light">Kontakt</span>
    </nav>
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-mc-light">Skontaktuj się z nami</h1>
    <p class="text-mc-muted mt-2 max-w-2xl">Masz pytania dotyczące naszych wycieczek? Chętnie pomożemy zaplanować Twoją podróż.</p>
  </div>
</section>

<section class="py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Contact Form -->
      <div class="lg:col-span-2">
        <% if (success) { %>
          <div class="bg-green-50 border border-green-200 text-green-700 px-6 py-4 rounded-xl mb-8">
            <div class="flex items-start space-x-3">
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <div>
                <p class="font-semibold">Wiadomość wysłana!</p>
                <p class="text-sm mt-1">Dziękujemy za kontakt. Odpowiemy najszybciej jak to możliwe.</p>
              </div>
            </div>
          </div>
        <% } %>

        <% if (error) { %>
          <div class="bg-red-50 border border-red-200 text-red-700 px-6 py-4 rounded-xl mb-8">
            <div class="flex items-start space-x-3">
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <p><%= error %></p>
            </div>
          </div>
        <% } %>

        <form action="/kontakt" method="POST" class="space-y-6">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-mc-light mb-2">Imię i nazwisko *</label>
              <input type="text" id="name" name="name" required
                     class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light placeholder-mc-muted/50 focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors">
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-mc-light mb-2">Email *</label>
              <input type="email" id="email" name="email" required
                     class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light placeholder-mc-muted/50 focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="phone" class="block text-sm font-medium text-mc-light mb-2">Telefon</label>
              <input type="tel" id="phone" name="phone"
                     class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light placeholder-mc-muted/50 focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors">
            </div>
            <div>
              <label for="tour_id" class="block text-sm font-medium text-mc-light mb-2">Zainteresowanie wycieczką</label>
              <select id="tour_id" name="tour_id"
                      class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors">
                <option value="">-- Wybierz wycieczkę (opcjonalnie) --</option>
                <% activeTours.forEach(t => { %>
                  <option value="<%= t.id %>"><%= t.title %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-mc-light mb-2">Wiadomość *</label>
            <textarea id="message" name="message" rows="5" required
                      class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 text-mc-light placeholder-mc-muted/50 focus:outline-none focus:border-mc-accent focus:ring-1 focus:ring-mc-accent transition-colors resize-y"></textarea>
          </div>

          <div>
            <label class="flex items-start space-x-3 cursor-pointer">
              <input type="checkbox" name="gdpr" value="1" required
                     class="mt-1 w-4 h-4 rounded border-gray-300 bg-mc-dark text-mc-accent focus:ring-mc-accent focus:ring-offset-0">
              <span class="text-sm text-mc-muted leading-relaxed">
                Wyrażam zgodę na przetwarzanie moich danych osobowych w celu obsługi zapytania, zgodnie z
                <a href="/dokumenty" class="text-mc-accent hover:text-mc-highlight">polityką prywatności</a>. *
              </span>
            </label>
          </div>

          <button type="submit"
                  class="bg-mc-accent hover:bg-mc-highlight text-mc-bg font-semibold px-8 py-3 rounded-lg transition-all text-sm w-full md:w-auto">
            Wyślij wiadomość
          </button>
        </form>
      </div>

      <!-- Contact Info Sidebar -->
      <div class="space-y-8">
        <div class="bg-mc-dark/50 rounded-xl border border-gray-200 p-6">
          <h3 class="font-heading font-semibold text-mc-light mb-6">Dane kontaktowe</h3>

          <div class="space-y-4">
            <div class="flex items-start space-x-3">
              <div class="w-10 h-10 rounded-lg bg-mc-accent/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-mc-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-mc-light">Adres</p>
                <p class="text-sm text-mc-muted">Szczecin, Polska</p>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-10 h-10 rounded-lg bg-mc-accent/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-mc-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-mc-light">Email</p>
                <a href="mailto:biuro@magnoliaclub.com.pl" class="text-sm text-mc-accent hover:text-mc-highlight transition-colors">biuro@magnoliaclub.com.pl</a>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-10 h-10 rounded-lg bg-mc-accent/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-mc-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-mc-light">Telefon</p>
                <a href="tel:+48571863855" class="text-sm text-mc-accent hover:text-mc-highlight transition-colors">+48 571 863 855</a>
              </div>
            </div>

            <div class="flex items-start space-x-3">
              <div class="w-10 h-10 rounded-lg bg-mc-accent/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-mc-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-mc-light">Godziny pracy</p>
                <p class="text-sm text-mc-muted">Pon-Pt: 9:00 - 17:00</p>
                <p class="text-sm text-mc-muted">Sob: 10:00 - 14:00</p>
              </div>
            </div>
          </div>
        </div>

        <!-- CEOTiP Registration -->
        <div class="bg-mc-dark/50 rounded-xl border border-gray-200 p-6">
          <div class="flex items-start space-x-3">
            <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-mc-light">Wpis do rejestru</p>
              <p class="text-sm text-mc-muted leading-relaxed">Centralna Ewidencja Organizatorów Turystyki i Przedsiębiorców</p>
              <p class="text-sm text-mc-accent font-semibold mt-1">Nr ewidencyjny: 35327</p>
            </div>
          </div>
        </div>

        <!-- Map Placeholder -->
        <div class="bg-mc-dark/50 rounded-xl border border-gray-200 overflow-hidden">
          <div class="aspect-square bg-mc-dark flex items-center justify-center">
            <div class="text-center">
              <svg class="w-12 h-12 text-mc-muted mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
              <p class="text-mc-muted text-sm">Google Maps</p>
              <p class="text-mc-muted text-xs">Szczecin, Polska</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
