<!-- Hero -->
<section class="bg-gradient-to-b from-gray-100 to-mc-bg py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-mc-muted mb-4">
      <a href="/" class="hover:text-mc-accent transition-colors">Strona główna</a>
      <span class="mx-2">/</span>
      <span class="text-mc-light">Blog</span>
    </nav>
    <h1 class="font-heading text-3xl md:text-4xl font-bold text-mc-light">Blog</h1>
    <p class="text-mc-muted mt-2 max-w-2xl">Historie, porady i inspiracje podróżnicze od zespołu Magnolia Club.</p>
  </div>
</section>

<!-- Category Filter -->
<section class="border-b border-gray-200 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap gap-2 py-4">
      <a href="/blog"
         class="px-4 py-2 rounded-full text-sm font-medium transition-all <%= currentCategory === 'all' ? 'bg-mc-accent text-white' : 'bg-white text-mc-muted hover:text-mc-light hover:bg-gray-50' %>">
        Wszystkie
      </a>
      <% categories.forEach(cat => { %>
        <a href="/blog?category=<%= encodeURIComponent(cat) %>"
           class="px-4 py-2 rounded-full text-sm font-medium transition-all <%= currentCategory === cat ? 'bg-mc-accent text-white' : 'bg-white text-mc-muted hover:text-mc-light hover:bg-gray-50' %>">
          <%= cat %>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- Posts Grid -->
<section class="py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if (posts.length === 0) { %>
      <div class="text-center py-16">
        <svg class="w-16 h-16 text-mc-muted mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
        </svg>
        <h3 class="font-heading text-xl text-mc-light mb-2">Brak artykułów</h3>
        <p class="text-mc-muted mb-4">Nie znaleziono artykułów w tej kategorii.</p>
        <a href="/blog" class="text-mc-accent hover:text-mc-highlight transition-colors">Pokaż wszystkie artykuły</a>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% posts.forEach(post => { %>
          <article class="bg-white rounded-xl overflow-hidden border border-gray-200 hover:border-mc-accent/30 transition-all duration-300 hover:-translate-y-1 group">
            <!-- Cover Image -->
            <a href="/blog/<%= post.slug %>" class="block aspect-video overflow-hidden">
              <% if (post.cover_image) { %>
                <img src="/uploads/blog/<%= post.cover_image %>" alt="<%= post.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              <% } else { %>
                <div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-100 flex items-center justify-center">
                  <svg class="w-12 h-12 text-mc-accent/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                  </svg>
                </div>
              <% } %>
            </a>

            <div class="p-6">
              <!-- Category + Date -->
              <div class="flex items-center justify-between mb-3">
                <% if (post.category) { %>
                  <span class="text-xs font-medium bg-mc-accent/20 text-mc-accent px-3 py-1 rounded-full"><%= post.category %></span>
                <% } %>
                <span class="text-xs text-mc-muted"><%= new Date(post.created_at).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
              </div>

              <!-- Title -->
              <h2 class="font-heading font-semibold text-lg text-mc-light mb-2 line-clamp-2">
                <a href="/blog/<%= post.slug %>" class="hover:text-mc-accent transition-colors"><%= post.title %></a>
              </h2>

              <!-- Excerpt -->
              <p class="text-mc-muted text-sm leading-relaxed line-clamp-3 mb-4"><%= post.excerpt %></p>

              <!-- Author + Read More -->
              <div class="flex items-center justify-between">
                <span class="text-xs text-mc-muted">
                  <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                  <%= post.author %>
                </span>
                <a href="/blog/<%= post.slug %>" class="text-mc-accent hover:text-mc-highlight text-sm font-medium transition-colors">
                  Czytaj dalej &rarr;
                </a>
              </div>
            </div>
          </article>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="flex justify-center items-center space-x-2 mt-12">
          <% if (currentPage > 1) { %>
            <a href="/blog?page=<%= currentPage - 1 %><%= currentCategory !== 'all' ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
               class="px-4 py-2 bg-white rounded-lg text-mc-muted hover:text-mc-light hover:bg-gray-50 transition-all text-sm">
              &larr; Nowsze
            </a>
          <% } %>

          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/blog?page=<%= i %><%= currentCategory !== 'all' ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
               class="w-10 h-10 flex items-center justify-center rounded-lg text-sm transition-all <%= i === currentPage ? 'bg-mc-accent text-white font-semibold' : 'bg-white text-mc-muted hover:text-mc-light' %>">
              <%= i %>
            </a>
          <% } %>

          <% if (currentPage < totalPages) { %>
            <a href="/blog?page=<%= currentPage + 1 %><%= currentCategory !== 'all' ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
               class="px-4 py-2 bg-white rounded-lg text-mc-muted hover:text-mc-light hover:bg-gray-50 transition-all text-sm">
              Starsze &rarr;
            </a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </div>
</section>
