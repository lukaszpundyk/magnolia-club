<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Magnolia Club - Biuro podróży ze Szczecina. Kameralne wycieczki w małych grupach. Slow travel, autentyczne doświadczenia.">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:type" content="website">
  <meta property="og:description" content="Kameralne wycieczki w małych grupach. Slow travel, autentyczne doświadczenia.">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin>
  <style>
    .mc-header { height: 72px; }
    .mc-header-logo { height: 100%; padding: 4px 0; display: flex; align-items: center; }
    .mc-header-logo img { height: 100%; width: auto; display: block; }
    .mc-main { padding-top: 72px; }
    @media (min-width: 768px) {
      .mc-header { height: 120px; }
      .mc-header-logo { padding: 2px 0; }
      .mc-main { padding-top: 120px; }
    }
  </style>
</head>
<body class="bg-mc-bg text-mc-light font-body min-h-screen flex flex-col">

  <!-- Navigation -->
  <nav class="fixed w-full top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mc-header">
        <!-- Logo -->
        <a href="/" class="flex items-center mc-header-logo">
          <img src="/images/logo.png" alt="Magnolia Club" onerror="this.style.display='none'">
        </a>

        <!-- Desktop Menu -->
        <div class="hidden md:flex items-center space-x-8">
          <a href="/" class="nav-link <%= currentPath === '/' ? 'text-mc-accent font-semibold' : 'text-mc-muted hover:text-mc-light' %> transition-colors font-medium text-base">Strona główna</a>
          <a href="/wycieczki" class="nav-link <%= currentPath.startsWith('/wycieczki') ? 'text-mc-accent font-semibold' : 'text-mc-muted hover:text-mc-light' %> transition-colors font-medium text-base">Wycieczki</a>
          <a href="/o-nas" class="nav-link <%= currentPath === '/o-nas' ? 'text-mc-accent font-semibold' : 'text-mc-muted hover:text-mc-light' %> transition-colors font-medium text-base">O nas</a>
          <a href="/blog" class="nav-link <%= currentPath.startsWith('/blog') ? 'text-mc-accent font-semibold' : 'text-mc-muted hover:text-mc-light' %> transition-colors font-medium text-base">Blog</a>
          <a href="/dokumenty" class="nav-link <%= currentPath === '/dokumenty' ? 'text-mc-accent font-semibold' : 'text-mc-muted hover:text-mc-light' %> transition-colors font-medium text-base">Dokumenty</a>
          <a href="/kontakt" class="bg-mc-accent hover:bg-mc-highlight text-white font-semibold px-6 py-2.5 rounded-lg transition-all text-base">Kontakt</a>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden text-mc-muted hover:text-mc-light p-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-200">
      <div class="px-4 py-4 space-y-3">
        <a href="/" class="block text-mc-muted hover:text-mc-light transition-colors py-2">Strona główna</a>
        <a href="/wycieczki" class="block text-mc-muted hover:text-mc-light transition-colors py-2">Wycieczki</a>
        <a href="/o-nas" class="block text-mc-muted hover:text-mc-light transition-colors py-2">O nas</a>
        <a href="/blog" class="block text-mc-muted hover:text-mc-light transition-colors py-2">Blog</a>
        <a href="/dokumenty" class="block text-mc-muted hover:text-mc-light transition-colors py-2">Dokumenty</a>
        <a href="/kontakt" class="block bg-mc-accent text-white font-semibold px-4 py-2 rounded-lg text-center">Kontakt</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="flex-grow mc-main">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="bg-mc-light border-t border-gray-200 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- Brand -->
        <div class="md:col-span-1">
          <span class="font-heading font-bold text-lg text-white mb-4 block">Magnolia Club</span>
          <p class="text-gray-400 text-sm leading-relaxed">Kameralne wycieczki w małych grupach. Odkrywaj świat inaczej — wolniej, głębiej, autentyczniej.</p>
        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Nawigacja</h4>
          <ul class="space-y-2">
            <li><a href="/wycieczki" class="text-gray-400 hover:text-white transition-colors text-sm">Wycieczki</a></li>
            <li><a href="/o-nas" class="text-gray-400 hover:text-white transition-colors text-sm">O nas</a></li>
            <li><a href="/blog" class="text-gray-400 hover:text-white transition-colors text-sm">Blog</a></li>
            <li><a href="/dokumenty" class="text-gray-400 hover:text-white transition-colors text-sm">Dokumenty</a></li>
            <li><a href="/kontakt" class="text-gray-400 hover:text-white transition-colors text-sm">Kontakt</a></li>
          </ul>
        </div>

        <!-- Contact Info -->
        <div>
          <h4 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Kontakt</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li class="flex items-start space-x-2">
              <svg class="w-4 h-4 mt-0.5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <span>Szczecin, Polska</span>
            </li>
            <li class="flex items-start space-x-2">
              <svg class="w-4 h-4 mt-0.5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <a href="mailto:biuro@magnoliaclub.com.pl" class="hover:text-white transition-colors">biuro@magnoliaclub.com.pl</a>
            </li>
            <li class="flex items-start space-x-2">
              <svg class="w-4 h-4 mt-0.5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <a href="tel:+48571863855" class="hover:text-white transition-colors">+48 571 863 855</a>
            </li>
          </ul>
        </div>

        <!-- Social -->
        <div>
          <h4 class="font-heading font-semibold text-white mb-4 text-sm uppercase tracking-wider">Obserwuj nas</h4>
          <div class="flex space-x-4">
            <a href="https://www.facebook.com/share/18MVjJuYQF/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="https://www.instagram.com/magnolia_club_travel?igsh=NTA4dHc3aWlyZ3dj&utm_source=qr" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-200 mt-8 pt-8 text-center text-gray-500 text-xs space-y-2">
        <p>Wpis do Centralnej Ewidencji Organizatorów Turystyki i Przedsiębiorców &mdash; nr ewidencyjny: <strong class="text-gray-400">35327</strong></p>
        <p>&copy; <%= new Date().getFullYear() %> Magnolia Club. Wszelkie prawa zastrzeżone.</p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuIcon.setAttribute('d', isOpen ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12');
    });
  </script>
</body>
</html>
